<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#F5F5F5">

    <TextView
        android:id="@+id/gi_tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Finance Manager"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#1A237E"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp"/>

    <EditText
        android:id="@+id/gi_edit_salary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Enter Salary ($)"
        android:inputType="numberDecimal"
        android:padding="14dp"
        android:textColor="#000000"
        android:background="@drawable/rounded_input"
        app:layout_constraintTop_toBottomOf="@id/gi_tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp"/>

    <EditText
        android:id="@+id/gi_edit_rent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Enter Rent ($)"
        android:inputType="numberDecimal"
        android:padding="14dp"
        android:textColor="#000000"
        android:background="@drawable/rounded_input"
        app:layout_constraintTop_toBottomOf="@id/gi_edit_salary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <EditText
        android:id="@+id/gi_edit_food"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Enter Food Expenses ($)"
        android:inputType="numberDecimal"
        android:padding="14dp"
        android:textColor="#000000"
        android:background="@drawable/rounded_input"
        app:layout_constraintTop_toBottomOf="@id/gi_edit_rent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <Button
        android:id="@+id/gi_btn_calculate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Calculate"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#1A237E"
        android:padding="14dp"
        app:layout_constraintTop_toBottomOf="@id/gi_edit_food"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>